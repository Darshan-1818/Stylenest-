<p class="text-success"><%= notice %></p>

<% content_for :title, "Stores" %>

<h1 class="mb-4">Stores</h1>

<div id="stores" class="container">
  <div class="row">
    <% @stores.each_with_index do |store, index| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <%= render store %>
            <p>
              <%= link_to "Show this store", store, class: "btn btn-primary mt-2" %>
            </p>
          </div>
        </div>
      </div>

      <%# Start a new row after every 3 items %>
      <% if (index + 1) % 3 == 0 %>
        </div><div class="row">
      <% end %>
    <% end %>
  </div>
</div>

<div class="mt-4">
  <%= link_to "New store", new_store_path, class: "btn btn-success" %>
</div>
