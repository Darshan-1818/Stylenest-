<div id="<%= dom_id store %>">
<%= image_tag store.cloth_image, height:"100", width:"100" if store.cloth_image.attached?%>
  <p>
    <strong>Name:</strong>
    <%= store.name %>
  </p>

  <p>
    <strong>Brand:</strong>
    <%= store.brand %>
  </p>

  <p>
    <strong>Price:</strong>
    <%= store.price %>
  </p>

  <p>
    <strong>Size:</strong>
    <%= store.size %>
  </p>

  <p>
    <strong>Description:</strong>
    <%= store.description %>
  </p>

</div>
