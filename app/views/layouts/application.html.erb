                        <% if session[:admin]%>
                        <li> <a href="/admin/logout">Admin  Logout </a></li>
                        <% else %>
                         <li> <a href="/admin/login">Admin  Login </a></li>
                         <% end %>
                       <% if alert %>
                         <p class="alert alert-danger"><%= alert %></p>
                       <% end %>
                        <p class="navbar-text float-right">
